{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  // All configuration names should be formatted ":<name> [qualifiers...]" so
  // that they are easy to distinguish and are grouped by name when sorted.
  "configurations": [
    {
      "name": ":run eval",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "args": [
        "eval",
      ],
    },
    {
      "name": ":debug eval",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "debugAdapter": "dlv-dap",
      "host": "localhost",
      "port": 2345,
      "preLaunchTask": "!debug eval",
      "postDebugTask": "!debug clean",
    },
  ]
}
